<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E1E"
    android:padding="12dp">
    <!-- SAME DROPDOWN so user can switch back -->
    <Spinner
        android:id="@+id/pageSpinner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:backgroundTint="#F8F8F2"
        android:popupBackground="#2B2B2B" />

    <!-- MODULE SELECTOR -->
    <LinearLayout
        android:id="@+id/moduleSelector"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_dropdown"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:layout_margin="12dp">

        <TextView
            android:id="@+id/tvModuleSelected"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Select a module..."
            android:textColor="#F8F8F2"
            android:textSize="14sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvChevron"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▾"
            android:textColor="#888888"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- TERMINAL OUTPUT -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#2B2B2B"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="#F8F8F2"
            android:textSize="13sp"
            android:text="Not connected.\n"/>

    </ScrollView>

    <!-- HIDDEN CAMERA VIEW FOR ARCORE -->
    <SurfaceView
        android:id="@+id/arSurface"
        android:layout_width="1px"
        android:layout_height="1px"
        android:visibility="gone"/>

    <!-- CONNECT BUTTON -->
    <Button
        android:id="@+id/btnConnect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Find Host &amp; Connect"
        android:layout_marginBottom="12dp"/>

    <!-- CONNECTION PASSWORD -->
    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="SSH Password"
        android:inputType="textPassword"
        android:layout_marginBottom="12dp"/>

</LinearLayout>